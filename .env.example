# ─────────────────────────────────────────────────────────────
# Supabase 연동
#
# supabaseClient.ts 에 접속 기본값이 내장돼 있어, 이 두 값을 비워도
# 기본적으로 "Supabase(클라우드) 모드"로 동작합니다.
# 자신의 Supabase 프로젝트로 바꾸려면 아래 두 값을 채우세요.
# (값 얻는 법: docs/실서비스-설정.md)
# ─────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────
# 링크 미리보기(OG) — 추가 설정 불필요
#
# 카카오톡·슬랙 미리보기 카드(회사명+로고)는 견적 토큰만으로 동작합니다.
# 로고는 발송 시점에 견적(supplier.logoUrl)에 스냅샷되어, 익명 접근 가능한
# get_quote_by_token RPC 로 함께 내려옵니다. 서비스롤 키·스키마 변경이 필요 없습니다.
# ─────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────
# 로컬 전용 스위치
#
# 1 (또는 true) 로 두면 위 Supabase 를 무시하고 브라우저(localStorage)
# 계정으로 동작합니다. 클라우드 없이 로컬에서 회원가입/로그인을 테스트할 때 사용.
# 비워두면 Supabase 모드(기본). ※ 로컬 계정은 실보안이 아닙니다.
# ─────────────────────────────────────────────────────────────
VITE_DISABLE_SUPABASE=
